#!/bin/bash

GATEWAY=$(ip route show default 2>/dev/null | awk '{print $3}')
LOCAL=$(ip route show default 2>/dev/null | awk '{print $9}')

if [[ -z "$GATEWAY" ]]; then
	printf "\uf071 (no default route)"
	exit 1
fi

if ping -c 1 -W 1 "$GATEWAY" >/dev/null 2>&1; then
	printf "\uf1eb "
	exit 0
else
	printf "\uf071 (gateway unreachable)"
	exit 1
fi
